#! /bin/sh

DOT_STOW_HOME="${DOT_STOW_HOME:-$HOME/F-dotfiles}"
PACKAGE=$1
HOSTNAME=`hostname -s`
OS=`uname`
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

stowit(){
    local dest=$1
    local source=$2
    local package=$3
    shift 3
    if [ -d ${source}/${package} ]; then
      echo  stow -t ${dest} -d ${source} ${package} "$@";
      stow -t ${dest} -d ${source} ${package} "$@";
    fi
}

# First stow base package
# folding is allowed because this dir has a .stow file
stowit ~ ${DOT_STOW_HOME} ${PACKAGE}

# Then stow OS specific version
stowit ~ ${DOT_STOW_HOME}/${PACKAGE} @${OS} --no-folding

# Then stow host specific version
stowit ~ ${DOT_STOW_HOME}/${PACKAGE} @${HOSTNAME} --no-folding

# Special handle @config puttiing it in the XDG_CONFIG_HOME

# First stow base config
stowit "${XDG_CONFIG_HOME}" ${DOT_STOW_HOME}/${PACKAGE} @config --no-folding

# Then stow OS config
stowit "${XDG_CONFIG_HOME}" ${DOT_STOW_HOME}/${PACKAGE}/@config @${OS} --no-folding

# Then stow host config
stowit "${XDG_CONFIG_HOME}" ${DOT_STOW_HOME}/${PACKAGE}/@config @${HOSTNAME} --no-folding


