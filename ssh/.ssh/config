# config: SSH client configuration

# Active settings for all hosts
Host *
    # Automatically add SSH keys to the SSH agent
    AddKeysToAgent yes
    # Keep connections alive by sending keep-alive signals
    ServerAliveInterval 120
    ServerAliveCountMax 30
    # Enable compression for faster connections on slow networks
    Compression yes
    # Verify and hash host names in the known_hosts file
    HashKnownHosts yes
    # Prompt before adding new hosts to known_hosts
    StrictHostKeyChecking ask
    # Enable SSH multiplexing to share connections and reduce Yubikey touches
    ControlMaster auto
    ControlPath ~/.ssh/control-%C
    ControlPersist 4h

